# /etc/systemd/system/daphne.service
# Replace User, WorkingDirectory, paths to venv and project.

[Unit]
Description=Daphne ASGI (Emotion Chat)
After=network.target

[Service]
Type=simple
User=REPLACE_USER
Group=REPLACE_USER
WorkingDirectory=/home/REPLACE_USER/chat_bot/emotion_chat
Environment=PATH=/home/REPLACE_USER/chat_bot/emotion_chat/.venv/bin
ExecStart=/home/REPLACE_USER/chat_bot/emotion_chat/.venv/bin/daphne \
    -b 127.0.0.1 -p 8000 emotion_chat.asgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
