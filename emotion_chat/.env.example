SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=emotion_chat
DB_USER=emotion
DB_PASSWORD=emotion
DB_HOST=localhost
DB_PORT=5432

# LLM (Gemini: set GEMINI_API_KEY and/or GOOGLE_API_KEY in env)
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Redis (optional — cache, Celery broker, Channels)
REDIS_URL=
# If unset, Celery defaults to redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=True

# JWT lifetimes (minutes / hours)
JWT_ACCESS_MINUTES=30
JWT_REFRESH_HOURS=24

# REST pagination
REST_PAGE_SIZE=50

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (defaults to console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

LOG_LEVEL=INFO
