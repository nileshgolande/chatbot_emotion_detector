# Copy to `.env` next to manage.py (never commit real `.env`).
# Production host: https://www.myemotionaichatbot.duckdns.org
#
# Local parity with Docker (from `emotion_chat/`):  docker compose up -d
# That starts Postgres + Redis; use the DB_* and REDIS_URL defaults below.

# Use a long random string (50+ chars); `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Django hosts (comma-separated, no spaces). Include www + apex if both resolve.
ALLOWED_HOSTS=www.myemotionaichatbot.duckdns.org,myemotionaichatbot.duckdns.org,localhost,127.0.0.1

# CORS: include your public HTTPS origin(s) + local dev CRA if needed.
CORS_ALLOWED_ORIGINS=https://www.myemotionaichatbot.duckdns.org,https://myemotionaichatbot.duckdns.org,http://localhost:3000,http://127.0.0.1:3000

# Must use https:// origins when using HTTPS (comma-separated).
CSRF_TRUSTED_ORIGINS=https://www.myemotionaichatbot.duckdns.org,https://myemotionaichatbot.duckdns.org,http://localhost:3000,http://127.0.0.1:3000

# Behind nginx with TLS: nginx sends X-Forwarded-Proto / Host.
TRUST_PROXY_SSL=1
USE_X_FORWARDED_HOST=1
# Let nginx redirect HTTP→HTTPS; keep False to avoid double redirects.
SECURE_SSL_REDIRECT=False

# Database (matches emotion_chat/docker-compose.yml service `db` by default)
DB_NAME=emotion_chat
DB_USER=emotion
DB_PASSWORD=emotion
DB_HOST=127.0.0.1
DB_PORT=5432
# Use require or verify-full for managed Postgres (e.g. Azure). Omit or empty for local/no TLS.
DB_SSLMODE=

# Redis: one REDIS_URL powers Django cache + Channels layer (required for multi-worker Daphne).
REDIS_URL=redis://127.0.0.1:6379/0
# Optional overrides (defaults fall back to REDIS_URL / built-in dev defaults):
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# LLM keys — set in real `.env` only
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Provider order for chat/journal LLM calls (see services/llm_service.py).
LLM_ORDER=gemini,groq,openrouter
USE_LANGGRAPH_CHAT=1
